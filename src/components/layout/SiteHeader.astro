---
import { navigation } from "../../data/navigation";

interface Props {
  pathname: string;
}

const { pathname } = Astro.props;
const isActive = (href: string) =>
  href === "/" ? pathname === "/" : pathname.startsWith(href);
---

<header class="site-header">
  <a class="brand serif" href="/">HeArt To Heart</a>
  <nav aria-label="Primary navigation">
    <ul>
      {
        navigation.map((item) => (
          <li>
            <a class:list={{ active: isActive(item.href) }} href={item.href}>
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
  <span class="search-mark" aria-hidden="true"></span>
</header>

<style>
  .site-header {
    position: absolute;
    z-index: 30;
    top: 0;
    left: 0;
    display: flex;
    width: 1440px;
    height: 81px;
    align-items: center;
    border-bottom: 1px solid rgba(207, 206, 206, 0.3);
    background: rgba(253, 252, 251, 0.98);
  }

  .brand {
    position: absolute;
    left: 50px;
    color: var(--ink);
    font-size: 24px;
    font-style: italic;
    font-weight: 700;
    letter-spacing: -0.6px;
  }

  nav {
    position: absolute;
    right: 80px;
  }

  ul {
    display: flex;
    margin: 0;
    align-items: center;
    gap: 34px;
    list-style: none;
  }

  nav a {
    position: relative;
    display: block;
    padding: 33px 0 31px;
    color: #57534e;
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 1.8px;
    white-space: nowrap;
  }

  nav a.active {
    color: var(--gold);
  }

  nav a.active::after {
    position: absolute;
    right: 0;
    bottom: 25px;
    left: 0;
    height: 1px;
    background: var(--gold);
    content: "";
  }

  .search-mark {
    position: absolute;
    right: 48px;
    width: 13px;
    height: 13px;
    border: 1px solid #78716d;
    border-radius: 50%;
  }

  .search-mark::after {
    position: absolute;
    right: -4px;
    bottom: -3px;
    width: 5px;
    height: 1px;
    background: #78716d;
    content: "";
    transform: rotate(45deg);
  }
</style>
