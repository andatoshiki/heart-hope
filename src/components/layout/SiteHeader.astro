---
import { navigation } from "../../data/navigation";

interface Props {
  pathname: string;
}

const { pathname } = Astro.props;
const isActive = (href: string) =>
  href === "/" ? pathname === "/" : pathname.startsWith(href);
---

<header class="site-header">
  <a class="brand serif" href="/">HeArt To Heart</a>
  <nav class="desktop-nav" aria-label="Primary navigation">
    <ul>
      {
        navigation.map((item) => (
          <li class:list={{ "toolbox-menu": item.href === "/toolbox" }}>
            <a class:list={{ active: isActive(item.href) }} href={item.href}>
              {item.label}
              {item.href === "/toolbox" && (
                <span class="menu-chevron" aria-hidden="true" />
              )}
            </a>
            {item.href === "/toolbox" && (
              <div class="toolbox-dropdown">
                <strong class="serif">VISUAL ARTS</strong>
                <a href="/toolbox?category=drawing-collage">
                  Drawing &amp; Collage
                </a>
                <a href="/toolbox?category=music-sound">Music &amp; Sound</a>
                <a href="/toolbox?category=writing-poetry">
                  Writing &amp; Poetry
                </a>
                <a href="/toolbox?category=movement-drama">
                  Movement &amp; Drama
                </a>
              </div>
            )}
          </li>
        ))
      }
    </ul>
  </nav>
  <span class="search-mark" aria-hidden="true"></span>
  <details class="mobile-menu">
    <summary aria-label="Open navigation">
      <span></span>
      <span></span>
      <span></span>
    </summary>
    <nav aria-label="Mobile navigation">
      {
        navigation.map((item) => (
          <a class:list={{ active: isActive(item.href) }} href={item.href}>
            {item.label}
          </a>
        ))
      }
      <div class="mobile-toolbox-links">
        <strong class="serif">VISUAL ARTS</strong>
        <a href="/toolbox?category=drawing-collage">Drawing &amp; Collage</a>
        <a href="/toolbox?category=music-sound">Music &amp; Sound</a>
        <a href="/toolbox?category=writing-poetry">Writing &amp; Poetry</a>
        <a href="/toolbox?category=movement-drama">Movement &amp; Drama</a>
      </div>
    </nav>
  </details>
</header>

<style>
  .site-header {
    position: absolute;
    z-index: 30;
    top: 0;
    left: 0;
    display: flex;
    width: 1440px;
    height: 81px;
    align-items: center;
    border-bottom: 1px solid rgba(207, 206, 206, 0.3);
    background: rgba(253, 252, 251, 0.98);
  }

  .brand {
    position: absolute;
    left: 50px;
    color: var(--ink);
    font-size: 24px;
    font-style: italic;
    font-weight: 700;
    letter-spacing: -0.6px;
  }

  nav {
    position: absolute;
    right: 80px;
  }

  ul {
    display: flex;
    margin: 0;
    align-items: center;
    gap: 34px;
    list-style: none;
  }

  nav a {
    position: relative;
    display: block;
    padding: 33px 0 31px;
    color: #57534e;
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 1.8px;
    white-space: nowrap;
  }

  nav li {
    position: relative;
  }

  .toolbox-menu > a {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .menu-chevron {
    width: 8px;
    height: 8px;
    margin-top: -4px;
    border-right: 1px solid currentColor;
    border-bottom: 1px solid currentColor;
    transform: rotate(45deg);
  }

  .toolbox-dropdown {
    position: absolute;
    z-index: 40;
    top: calc(100% + 2px);
    left: -32px;
    display: grid;
    width: 256px;
    height: 210px;
    visibility: hidden;
    padding: 28px 32px 24px;
    border: 1px solid #eeeae5;
    background: #fff;
    box-shadow: 0 12px 24px rgba(18, 18, 18, 0.08);
    opacity: 0;
    transform: translateY(-6px);
    transition: visibility 0s linear 140ms, opacity 140ms ease,
      transform 140ms ease;
  }

  .toolbox-menu:hover .toolbox-dropdown,
  .toolbox-menu:focus-within .toolbox-dropdown {
    visibility: visible;
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0s;
  }

  .toolbox-dropdown strong {
    color: var(--olive);
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 1.3px;
  }

  nav .toolbox-dropdown a {
    padding: 0;
    color: #72716f;
    font-size: 14px;
    font-weight: 400;
    letter-spacing: 0.5px;
    line-height: 1;
  }

  nav .toolbox-dropdown a::after {
    content: none;
  }

  nav .toolbox-dropdown a:hover,
  nav .toolbox-dropdown a:focus-visible {
    color: var(--gold);
  }

  nav a.active {
    color: var(--gold);
  }

  nav a.active::after {
    position: absolute;
    right: 0;
    bottom: 25px;
    left: 0;
    height: 1px;
    background: var(--gold);
    content: "";
  }

  .search-mark {
    position: absolute;
    right: 48px;
    width: 13px;
    height: 13px;
    border: 1px solid #78716d;
    border-radius: 50%;
  }

  .search-mark::after {
    position: absolute;
    right: -4px;
    bottom: -3px;
    width: 5px;
    height: 1px;
    background: #78716d;
    content: "";
    transform: rotate(45deg);
  }

  .mobile-menu {
    display: none;
  }

  @media (max-width: 1439px) {
    .site-header {
      position: sticky;
      width: 100%;
      height: var(--mobile-header-height);
      background: rgba(253, 252, 251, 0.96);
      backdrop-filter: blur(12px);
    }

    .brand {
      left: var(--page-gutter);
      font-size: 21px;
    }

    .desktop-nav,
    .search-mark {
      display: none;
    }

    .mobile-menu {
      position: absolute;
      right: var(--page-gutter);
      display: block;
    }

    .mobile-menu summary {
      display: grid;
      width: 44px;
      height: 44px;
      cursor: pointer;
      list-style: none;
      place-content: center;
      gap: 5px;
    }

    .mobile-menu summary::-webkit-details-marker {
      display: none;
    }

    .mobile-menu summary span {
      display: block;
      width: 20px;
      height: 1px;
      background: var(--ink);
      transition: transform 160ms ease, opacity 160ms ease;
    }

    .mobile-menu[open] summary span:first-child {
      transform: translateY(6px) rotate(45deg);
    }

    .mobile-menu[open] summary span:nth-child(2) {
      opacity: 0;
    }

    .mobile-menu[open] summary span:last-child {
      transform: translateY(-6px) rotate(-45deg);
    }

    .mobile-menu nav {
      position: fixed;
      top: var(--mobile-header-height);
      right: 0;
      left: 0;
      display: grid;
      max-height: calc(100dvh - var(--mobile-header-height));
      overflow-y: auto;
      padding: 20px var(--page-gutter) 36px;
      border-top: 1px solid #eeeae5;
      background: var(--canvas);
      box-shadow: 0 18px 30px rgba(18, 18, 18, 0.08);
    }

    .mobile-menu nav > a {
      min-height: 48px;
      padding: 16px 0;
      border-bottom: 1px solid #eeeae5;
      color: var(--ink-soft);
      font-size: 11px;
      letter-spacing: 1.8px;
    }

    .mobile-menu nav > a.active {
      color: var(--gold);
    }

    .mobile-menu nav > a.active::after {
      bottom: 0;
    }

    .mobile-toolbox-links {
      display: grid;
      margin-top: 22px;
      gap: 4px;
    }

    .mobile-toolbox-links strong {
      margin-bottom: 8px;
      color: var(--olive);
      font-size: 11px;
      letter-spacing: 1.8px;
    }

    .mobile-toolbox-links a {
      min-height: 44px;
      padding: 12px 0;
      color: #72716f;
      font-size: 11px;
      letter-spacing: 1.8px;
    }
  }

  @media (min-width: 1200px) and (max-width: 1439px) {
    .desktop-nav,
    .search-mark {
      display: block;
    }

    .mobile-menu {
      display: none;
    }
  }
</style>
