---
import { navigation } from "../../data/navigation";

interface Props {
  pathname: string;
}

const { pathname } = Astro.props;
const isActive = (href: string) =>
  href === "/" ? pathname === "/" : pathname.startsWith(href);
---

<header class="site-header">
  <a class="brand serif" href="/">HeArt To Heart</a>
  <nav class="desktop-nav" aria-label="Primary navigation">
    <ul>
      {
        navigation.map((item) => (
          <li class:list={{ "toolbox-menu": item.href === "/toolbox" }}>
            <a class:list={{ active: isActive(item.href) }} href={item.href}>
              {item.label}
              {item.href === "/toolbox" && (
                <span class="menu-chevron" aria-hidden="true" />
              )}
            </a>
            {item.href === "/toolbox" && (
              <div class="toolbox-dropdown">
                <strong class="serif">VISUAL ARTS</strong>
                <a href="/toolbox?category=drawing-collage">
                  Drawing &amp; Collage
                </a>
                <a href="/toolbox?category=music-sound">Music &amp; Sound</a>
                <a href="/toolbox?category=writing-poetry">
                  Writing &amp; Poetry
                </a>
                <a href="/toolbox?category=movement-drama">
                  Movement &amp; Drama
                </a>
              </div>
            )}
          </li>
        ))
      }
    </ul>
  </nav>
  <button
    class="search-toggle"
    type="button"
    aria-label="Open search"
    aria-expanded="false"
    aria-controls="site-search"
  >
    <span class="search-mark" aria-hidden="true"></span>
  </button>
  <div class="search-panel" id="site-search" inert>
    <span class="search-mark search-mark--field" aria-hidden="true"></span>
    <input
      class="search-field"
      type="search"
      placeholder="Search the site"
      aria-label="Search the site"
      autocomplete="off"
    />
    <button class="search-close" type="button" aria-label="Close search">
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
    </button>
  </div>
  <details class="mobile-menu">
    <summary aria-label="Open navigation">
      <span></span>
      <span></span>
      <span></span>
    </summary>
    <nav aria-label="Mobile navigation">
      {
        navigation.map((item) => (
          <a class:list={{ active: isActive(item.href) }} href={item.href}>
            {item.label}
          </a>
        ))
      }
      <div class="mobile-toolbox-links">
        <strong class="serif">VISUAL ARTS</strong>
        <a href="/toolbox?category=drawing-collage">Drawing &amp; Collage</a>
        <a href="/toolbox?category=music-sound">Music &amp; Sound</a>
        <a href="/toolbox?category=writing-poetry">Writing &amp; Poetry</a>
        <a href="/toolbox?category=movement-drama">Movement &amp; Drama</a>
      </div>
    </nav>
  </details>
</header>

<style>
  .site-header {
    position: absolute;
    z-index: 30;
    top: 0;
    left: 50%;
    display: flex;
    width: 1440px;
    height: 81px;
    align-items: center;
    border-bottom: 1px solid rgba(207, 206, 206, 0.3);
    background: rgba(253, 252, 251, 0.98);
    transform: translateX(-50%);
  }

  .brand {
    position: absolute;
    left: 50px;
    color: var(--ink);
    font-size: 24px;
    font-style: italic;
    font-weight: 700;
    letter-spacing: -0.6px;
  }

  nav {
    position: absolute;
    right: 80px;
  }

  ul {
    display: flex;
    margin: 0;
    align-items: center;
    gap: 34px;
    list-style: none;
  }

  nav a {
    position: relative;
    display: block;
    padding: 33px 0 31px;
    color: #57534e;
    font-size: 14px;
    font-weight: 400;
    letter-spacing: 1.8px;
    white-space: nowrap;
  }

  nav li {
    position: relative;
  }

  .toolbox-menu > a {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .menu-chevron {
    width: 8px;
    height: 8px;
    margin-top: -4px;
    border-right: 1px solid currentColor;
    border-bottom: 1px solid currentColor;
    transform: rotate(45deg);
  }

  .toolbox-dropdown {
    position: absolute;
    z-index: 40;
    top: calc(100% + 2px);
    left: -32px;
    display: grid;
    width: 256px;
    height: 210px;
    visibility: hidden;
    padding: 28px 32px 24px;
    border: 1px solid #eeeae5;
    background: #fff;
    box-shadow: 0 12px 24px rgba(18, 18, 18, 0.08);
    opacity: 0;
    transform: translateY(-6px);
    transition: visibility 0s linear 140ms, opacity 140ms ease,
      transform 140ms ease;
  }

  .toolbox-menu:hover .toolbox-dropdown,
  .toolbox-menu:focus-within .toolbox-dropdown {
    visibility: visible;
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0s;
  }

  .toolbox-dropdown strong {
    color: var(--olive);
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 1.3px;
  }

  nav .toolbox-dropdown a {
    padding: 0;
    color: #72716f;
    font-size: 14px;
    font-weight: 400;
    letter-spacing: 0.5px;
    line-height: 1;
  }

  nav .toolbox-dropdown a::after {
    content: none;
  }

  nav .toolbox-dropdown a:hover,
  nav .toolbox-dropdown a:focus-visible {
    color: var(--gold);
  }

  nav a.active {
    color: var(--gold);
  }

  nav a.active::after {
    position: absolute;
    right: 0;
    bottom: 25px;
    left: 0;
    height: 1px;
    background: var(--gold);
    content: "";
  }

  .search-toggle {
    position: absolute;
    right: 41px;
    display: grid;
    width: 36px;
    height: 36px;
    border: 0;
    border-radius: 50%;
    background: transparent;
    place-items: center;
    transition: opacity 160ms ease, background 160ms ease;
  }

  .search-toggle:hover {
    background: rgba(120, 113, 109, 0.08);
  }

  .search-mark {
    position: relative;
    width: 13px;
    height: 13px;
    border: 1px solid #78716d;
    border-radius: 50%;
  }

  .search-mark::after {
    position: absolute;
    right: -4px;
    bottom: -3px;
    width: 5px;
    height: 1px;
    background: #78716d;
    content: "";
    transform: rotate(45deg);
  }

  .search-panel {
    position: absolute;
    z-index: 5;
    inset: 0;
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 0 41px 0 50px;
    background: rgba(253, 252, 251, 0.98);
    clip-path: inset(0 0 0 100%);
    pointer-events: none;
    transition: clip-path 380ms cubic-bezier(0.22, 1, 0.36, 1),
      visibility 0s linear 380ms;
    visibility: hidden;
  }

  .search-mark--field {
    flex: 0 0 auto;
    width: 16px;
    height: 16px;
  }

  .search-field {
    flex: 1;
    min-width: 0;
    height: 44px;
    border: 0;
    background: transparent;
    color: var(--ink);
    font-family: "Playfair Display", serif;
    font-size: 22px;
    font-style: italic;
    letter-spacing: 0.3px;
    opacity: 0;
    transition: opacity 260ms ease 120ms;
  }

  .search-field::placeholder {
    color: #a8a29d;
  }

  .search-field:focus {
    outline: none;
  }

  .search-close {
    position: relative;
    flex: 0 0 auto;
    width: 34px;
    height: 34px;
    border: 0;
    border-radius: 50%;
    background: transparent;
    transition: background 160ms ease;
  }

  .search-close:hover {
    background: rgba(120, 113, 109, 0.08);
  }

  .search-close span {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 16px;
    height: 1px;
    background: #57534e;
  }

  .search-close span:first-child {
    transform: translate(-50%, -50%) rotate(45deg);
  }

  .search-close span:last-child {
    transform: translate(-50%, -50%) rotate(-45deg);
  }

  .is-search-open .search-toggle {
    opacity: 0;
    pointer-events: none;
  }

  .is-search-open .search-panel {
    clip-path: inset(0 0 0 0);
    pointer-events: auto;
    visibility: visible;
    transition: clip-path 380ms cubic-bezier(0.22, 1, 0.36, 1),
      visibility 0s;
  }

  .is-search-open .search-field {
    opacity: 1;
  }

  .mobile-menu {
    display: none;
  }

  @media (max-width: 1439px) {
    .site-header {
      position: sticky;
      left: 0;
      width: 100%;
      height: var(--mobile-header-height);
      background: rgba(253, 252, 251, 0.96);
      backdrop-filter: blur(12px);
      transform: none;
    }

    .brand {
      left: var(--page-gutter);
      font-size: 21px;
    }

    .desktop-nav,
    .search-toggle,
    .search-panel {
      display: none;
    }

    .mobile-menu {
      position: absolute;
      right: var(--page-gutter);
      display: block;
    }

    .mobile-menu summary {
      display: grid;
      width: 44px;
      height: 44px;
      cursor: pointer;
      list-style: none;
      place-content: center;
      gap: 5px;
    }

    .mobile-menu summary::-webkit-details-marker {
      display: none;
    }

    .mobile-menu summary span {
      display: block;
      width: 20px;
      height: 1px;
      background: var(--ink);
      transition: transform 160ms ease, opacity 160ms ease;
    }

    .mobile-menu[open] summary span:first-child {
      transform: translateY(6px) rotate(45deg);
    }

    .mobile-menu[open] summary span:nth-child(2) {
      opacity: 0;
    }

    .mobile-menu[open] summary span:last-child {
      transform: translateY(-6px) rotate(-45deg);
    }

    .mobile-menu nav {
      position: fixed;
      top: var(--mobile-header-height);
      right: 0;
      left: 0;
      display: grid;
      max-height: calc(100dvh - var(--mobile-header-height));
      overflow-y: auto;
      padding: 20px var(--page-gutter) 36px;
      border-top: 1px solid #eeeae5;
      background: var(--canvas);
      box-shadow: 0 18px 30px rgba(18, 18, 18, 0.08);
    }

    .mobile-menu nav > a {
      min-height: 48px;
      padding: 16px 0;
      border-bottom: 1px solid #eeeae5;
      color: var(--ink-soft);
      font-size: 11px;
      letter-spacing: 1.8px;
    }

    .mobile-menu nav > a.active {
      color: var(--gold);
    }

    .mobile-menu nav > a.active::after {
      bottom: 0;
    }

    .mobile-toolbox-links {
      display: grid;
      margin-top: 22px;
      gap: 4px;
    }

    .mobile-toolbox-links strong {
      margin-bottom: 8px;
      color: var(--olive);
      font-size: 11px;
      letter-spacing: 1.8px;
    }

    .mobile-toolbox-links a {
      min-height: 44px;
      padding: 12px 0;
      color: #72716f;
      font-size: 11px;
      letter-spacing: 1.8px;
    }
  }

  @media (min-width: 1200px) and (max-width: 1439px) {
    .desktop-nav {
      display: block;
    }

    .search-toggle {
      display: grid;
    }

    .search-panel {
      display: flex;
    }

    .mobile-menu {
      display: none;
    }
  }
</style>

<script>
  const header = document.querySelector<HTMLElement>(".site-header");
  const toggle = header?.querySelector<HTMLButtonElement>(".search-toggle");
  const panel = header?.querySelector<HTMLElement>("#site-search");
  const field = panel?.querySelector<HTMLInputElement>(".search-field");
  const closeButton = panel?.querySelector<HTMLButtonElement>(".search-close");

  if (header && toggle && panel && field && closeButton) {
    const openSearch = () => {
      header.classList.add("is-search-open");
      toggle.setAttribute("aria-expanded", "true");
      panel.removeAttribute("inert");
      field.focus();
    };

    const closeSearch = () => {
      header.classList.remove("is-search-open");
      toggle.setAttribute("aria-expanded", "false");
      panel.setAttribute("inert", "");
      field.value = "";
      toggle.focus();
    };

    toggle.addEventListener("click", openSearch);
    closeButton.addEventListener("click", closeSearch);

    field.addEventListener("keydown", (event) => {
      // UI-only demo: never submit, just collapse on Escape or Enter.
      if (event.key === "Escape" || event.key === "Enter") {
        event.preventDefault();
        closeSearch();
      }
    });
  }
</script>
