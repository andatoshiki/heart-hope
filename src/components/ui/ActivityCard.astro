---
import type { Activity } from "../../data/content";

interface Props {
  activity: Activity;
}

const { activity } = Astro.props;
---

<article class="activity-card" data-category={activity.category}>
  <div class="image-wrap">
    <img src={activity.image.src} alt="" />
    <h3 class="serif">{activity.categoryLabel}</h3>
  </div>
  <h4>{activity.title}</h4>
  <p>{activity.summary}</p>
  {
    activity.detailSlug ? (
      <a class="learn-more" href={activity.detailSlug}>LEARN MORE</a>
    ) : (
      <span class="learn-more">LEARN MORE</span>
    )
  }
</article>

<style>
  .activity-card {
    width: 380px;
  }

  .image-wrap {
    position: relative;
    height: 506px;
    overflow: hidden;
    border-radius: 20px;
  }

  img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  h3 {
    position: absolute;
    right: 24px;
    bottom: 28px;
    left: 24px;
    margin: 0;
    color: #fff;
    font-size: 36px;
    font-style: italic;
    font-weight: 700;
    letter-spacing: 0.04px;
    line-height: 48px;
    text-shadow: 0 2px 12px #000;
  }

  h4 {
    margin: 28px 0 12px;
    font-family: "Playfair Display", serif;
    font-size: 18px;
    font-weight: 700;
    letter-spacing: 0.6px;
  }

  p {
    min-height: 62px;
    margin: 0;
    color: #72716f;
    font-size: 12px;
    letter-spacing: 0.5px;
    line-height: 20px;
  }

  .learn-more {
    display: inline-block;
    margin-top: 20px;
    padding-bottom: 8px;
    border-bottom: 1px solid #c9c7c3;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 1.73px;
  }

  @media (max-width: 1439px) {
    .activity-card {
      width: 100%;
    }

    .image-wrap {
      height: auto;
      aspect-ratio: 3 / 4;
    }
  }
</style>
