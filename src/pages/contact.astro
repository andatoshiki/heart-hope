---
import ContactFormDemo from "../components/react/ContactFormDemo";
import PageHeading from "../components/ui/PageHeading.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Contact Us" height={1673}>
  <PageHeading title="Contact Us" subtitle="WE’D LOVE TO HEAR FROM YOU" />
  <section class="contact-copy">
    <h2 class="serif">Start a<br />healing conversation</h2>
    <p>
      Whether it's an inquiry about a work, a partnership proposal, or just
      wanting to share your story, we are always welcome.
    </p>
    <address>
      <div>
        <span class="icon">✉</span>
        <p><strong>EMAIL ADDRESS</strong>hello@hearttoheart.art</p>
      </div>
      <div>
        <span class="icon">⌕</span>
        <p><strong>PHONE NUMBER</strong>+886 2 2345 6789</p>
      </div>
      <div>
        <span class="icon">⌖</span>
        <p><strong>STUDIO ADDRESS</strong>No. 123, Art Street, Da'an District, Taipei City</p>
      </div>
    </address>
  </section>
  <ContactFormDemo client:load />
</BaseLayout>

<style>
  .contact-copy {
    position: absolute;
    top: 333px;
    left: 105px;
    width: 580px;
  }

  h2 {
    margin: 0;
    font-size: 32px;
    font-style: italic;
    font-weight: 700;
    line-height: 43px;
  }

  .contact-copy > p {
    margin: 22px 0 42px;
    color: var(--ink-soft);
    font-size: 14px;
    letter-spacing: 0.5px;
    line-height: 23px;
  }

  address {
    display: grid;
    gap: 32px;
    font-style: normal;
  }

  address div {
    display: flex;
    height: 56px;
    align-items: center;
    gap: 24px;
  }

  .icon {
    display: grid;
    width: 56px;
    height: 56px;
    place-items: center;
    border-radius: 12px;
    color: var(--olive);
    background: var(--surface);
    font-size: 20px;
  }

  address p {
    margin: 0;
    color: var(--ink);
    font-size: 14px;
    letter-spacing: 0.5px;
    line-height: 22px;
  }

  address strong {
    display: block;
    margin-bottom: 6px;
    color: #878683;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 1.3px;
  }
</style>
