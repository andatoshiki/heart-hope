---
import CorridorSubmissionDialog from "../components/react/CorridorSubmissionDialog";
import PageHeading from "../components/ui/PageHeading.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { corridorEntries } from "../data/content";
import safePlace from "../assets/images/corridor-safe-place.png";
---

<BaseLayout title='The "Right Now" Corridor' height={2383}>
  <PageHeading
    title={'The "Right Now" Corridor'}
    subtitle="A Gallery of Shared Feelings. You are not alone. This is a silent, anonymous gathering space."
  />
  <div class="corridor-tabs">
    <span>CURRENT</span>
    <span>PAST ISSUES</span>
  </div>
  <section class="theme-panel soft-panel">
    <div class="theme-copy">
      <span>CURRENT THEME</span>
      <h2 class="serif">A Safe Place</h2>
      <p>What does safety look, feel, or sound like to you?<br />Share a glimpse.</p>
      <div class="dialog-position"><CorridorSubmissionDialog client:load /></div>
    </div>
    <img src={safePlace.src} alt="A calm forest path" />
  </section>
  <section class="corridor-gallery">
    <article class="quote-card first-quote">
      <p class="serif">{corridorEntries[0].quote}</p>
      <span>{corridorEntries[0].attribution}</span>
    </article>
    <article class="image-card art-one">
      <img src={corridorEntries[1].image?.src} alt="" />
      <span>{corridorEntries[1].attribution}</span>
    </article>
    <article class="quote-card second-quote">
      <p class="serif">{corridorEntries[2].quote}</p>
      <span>{corridorEntries[2].attribution}</span>
    </article>
    <article class="image-card art-two">
      <img src={corridorEntries[3].image?.src} alt="" />
      <span>{corridorEntries[3].attribution}</span>
    </article>
  </section>
</BaseLayout>

<style>
  .corridor-tabs {
    position: absolute;
    top: 351px;
    left: 573px;
    display: grid;
    grid-template-columns: repeat(2, 140px);
    gap: 15px;
  }

  .corridor-tabs span {
    display: grid;
    height: 32px;
    place-items: center;
    border-radius: 999px;
    color: #57534e;
    background: #f5f2ed;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 1.2px;
  }

  .corridor-tabs span:first-child {
    color: #fff;
    background: var(--ink);
  }

  .theme-panel {
    position: absolute;
    top: 447px;
    left: 104px;
    display: grid;
    width: 1232px;
    height: 672px;
    align-items: center;
    padding: 67px 67px 67px 80px;
    grid-template-columns: 573px 512px;
    gap: 0;
  }

  .theme-copy > span {
    display: inline-grid;
    height: 24px;
    place-items: center;
    border-radius: 999px;
    padding: 0 18px;
    color: #fff;
    background: var(--olive);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 1.2px;
  }

  .theme-copy h2 {
    margin: 24px 0 16px;
    font-size: 58px;
    font-style: italic;
    font-weight: 400;
    line-height: 77px;
  }

  .theme-copy p {
    color: var(--ink-soft);
    font-size: 18px;
    letter-spacing: 0.3px;
    line-height: 29px;
  }

  .dialog-position {
    margin-top: 30px;
  }

  .theme-panel img {
    width: 512px;
    height: 536px;
    border-radius: 24px;
    object-fit: cover;
  }

  .corridor-gallery {
    position: absolute;
    top: 1183px;
    left: 104px;
    width: 1232px;
    height: 584px;
  }

  .corridor-gallery article {
    position: absolute;
  }

  .quote-card,
  .image-card img {
    border-radius: 24px;
    background: #f2f2f2;
  }

  .quote-card {
    display: flex;
    padding: 30px 32px;
    flex-direction: column;
    justify-content: space-between;
  }

  .quote-card p {
    margin: 0;
    font-size: 32px;
    font-style: italic;
    line-height: 43px;
  }

  article span {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 1.2px;
  }

  .first-quote {
    top: 0;
    left: 0;
    width: 390px;
    height: 163px;
  }

  .art-one {
    top: 0;
    left: 421px;
  }

  .art-two {
    top: 0;
    left: 842px;
  }

  .image-card img {
    display: block;
    width: 390px;
    height: 422px;
    object-fit: cover;
  }

  .image-card span {
    display: block;
    margin-top: 16px;
  }

  .second-quote {
    top: 453px;
    left: 421px;
    width: 390px;
    height: 131px;
  }

  .second-quote p {
    font-size: 24px;
    line-height: 33px;
  }

  @media (max-width: 1439px) {
    .corridor-tabs,
    .theme-panel,
    .corridor-gallery {
      position: relative;
      top: auto;
      left: auto;
      width: auto;
      height: auto;
      margin-right: var(--page-gutter);
      margin-left: var(--page-gutter);
    }

    .corridor-tabs {
      width: min(100%, 295px);
      margin-top: 48px;
      margin-right: auto;
      margin-left: auto;
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .theme-panel {
      margin-top: 52px;
      padding: clamp(32px, 7vw, 68px);
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      gap: clamp(36px, 6vw, 64px);
    }

    .theme-copy h2 {
      font-size: clamp(44px, 7vw, 58px);
      line-height: 1.2;
    }

    .theme-copy p br {
      display: none;
    }

    .theme-panel img {
      width: 100%;
      height: auto;
      aspect-ratio: 512 / 536;
    }

    .corridor-gallery {
      display: grid;
      margin-top: var(--section-gap);
      margin-bottom: var(--section-gap);
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 30px;
    }

    .corridor-gallery article,
    .first-quote,
    .art-one,
    .art-two,
    .second-quote {
      position: relative;
      top: auto;
      left: auto;
      width: auto;
      height: auto;
    }

    .quote-card {
      min-height: 190px;
    }

    .image-card img {
      width: 100%;
      height: auto;
      aspect-ratio: 390 / 422;
    }
  }

  @media (max-width: 767px) {
    .theme-panel,
    .corridor-gallery {
      grid-template-columns: 1fr;
    }

    .theme-panel img {
      grid-row: 1;
    }

    .quote-card p {
      font-size: 27px;
      line-height: 1.35;
    }
  }
</style>
