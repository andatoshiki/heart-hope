---
import { ArrowDown, ArrowRight } from "@lucide/astro";
import ActivityCard from "../components/ui/ActivityCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { activities } from "../data/content";
import blueFlower from "../assets/images/blue-flower.png";
import clock from "../assets/images/clock.jpg";
import corridorTree from "../assets/images/corridor-tree.png";
---

<BaseLayout title="Home" height={4162}>
  <script is:inline>
    if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      document.documentElement.classList.add("scrolly-enabled");
    }
  </script>
  <section
    class="hero full-bleed"
    aria-labelledby="hero-title"
    data-scrolly-hero
  >
    <p class="eyebrow">WELCOME TO HEART TO HEART</p>
    <h1 id="hero-title" class="serif">
      This is a space where feelings<br />can speak without words
    </h1>
    <a class="hero-button" href="/toolbox">
      <span>EXPLORE ART WORLD</span>
      <ArrowRight size={16} stroke-width={1.5} />
    </a>
    <div class="mountain"></div>
    <a
      class="scroll-cue"
      href="#home-about"
      aria-label="Scroll to the About section"
    >
      <span>SCROLL TO EXPLORE</span>
      <ArrowDown size={18} stroke-width={1.5} />
    </a>
  </section>

  <section id="home-about" class="home-about" data-scrolly>
    <div class="about-heading">
      <span class="eyebrow">ABOUT US</span>
      <h2 class="serif">HeART To Heart</h2>
    </div>
    <div class="about-copy">
      <p>
        <strong class="serif">H</strong>eart” and “Art.” True connection happens
        when we share our true hearts through the language of art. That's the
        journey we're on: from one heart to another.
      </p>
      <p>
        I started this because I often had feelings I couldn't name. Sometimes,
        words felt too small, too limiting. I felt confused, frustrated, and
        alone. Then, I discovered that putting a color to my mood, or moving to
        music, gave those feelings a home. It was a quiet revolution inside me. I
        wanted to build a bridge so others might find that path, too.
      </p>
    </div>
  </section>

  <section class="home-toolbox full-bleed" data-scrolly>
    <p class="eyebrow">WELCOME TO HEALING ACTIVITIES</p>
    <h2>Toolbox</h2>
    <div class="activity-row">
      {activities.slice(0, 3).map((activity) => <ActivityCard activity={activity} />)}
    </div>
  </section>

  <section class="home-healing full-bleed" data-scrolly>
    <p class="eyebrow">WELCOME TO ART HEALING</p>
    <h2>101</h2>
    <article class="healing-card left-card">
      <img src={blueFlower.src} alt="" />
      <div>
        <h3>What is Art Healing</h3>
        <p>
          It is a gentle way to explore your inner world through creativity. NO
          talent needed, only CURIOSITY.
        </p>
        <a href="/art-healing">LEARN MORE</a>
      </div>
    </article>
    <article class="healing-card right-card">
      <img src={clock.src} alt="" />
      <div>
        <h3>My “Why”</h3>
        <p>
          When words fall short, art can be a bridge. Art connects us to the
          present moment and our deeper selves.
        </p>
        <a href="/art-healing">LEARN MORE</a>
      </div>
    </article>
  </section>

  <section class="home-corridor" data-scrolly>
    <img src={corridorTree.src} alt="A quiet tree-lined path" />
    <div>
      <h2>The “Right Now” Corridor<br />A Gallery of Shared Feelings.</h2>
      <p>
        This is a silent, anonymous gathering space. Every month, we have a
        gentle theme. You are invited to contribute a small piece of your
        world—a photo, a few lines of text, a drawing, or a sound recording.
      </p>
      <a class="outline-button" href="/corridor">LEARN MORE</a>
    </div>
  </section>
</BaseLayout>

<script>
  import "../scripts/scrollytelling";
</script>

<style>
  /* Scrollytelling: each narrated section starts lifted + transparent and
     settles into place when Scrollama reports it has entered the viewport.
     Everything is gated behind `.scrolly-enabled` (added by an inline script
     only when motion is allowed), so without JS or with reduced motion the
     content renders normally. Only transforms/opacity change, never layout, so
     the fixed desktop canvas geometry is preserved. */
  :global(.scrolly-enabled) [data-scrolly] {
    opacity: 0;
    transform: translateY(48px);
    transition:
      opacity 0.8s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
    will-change: opacity, transform;
  }

  :global(.scrolly-enabled) [data-scrolly].is-inview {
    opacity: 1;
    transform: none;
  }

  .hero {
    position: absolute;
    top: 81px;
    width: 1440px;
    height: 732px;
    --full-bleed-background: var(--hero-blue);
    background: var(--hero-blue);
    clip-path: inset(0 calc(0px - var(--desktop-bleed)));
    text-align: center;
  }

  .hero .eyebrow {
    margin-top: 190px;
    color: #fff;
    transform: translateY(calc(var(--scrolly-progress, 0) * -22px));
  }

  .hero h1 {
    position: relative;
    z-index: 2;
    margin: 36px 0 32px;
    color: #fff;
    font-size: 74px;
    font-style: italic;
    font-weight: 400;
    letter-spacing: -3px;
    line-height: 99px;
    transform: translateY(calc(var(--scrolly-progress, 0) * -44px));
    opacity: calc(1 - var(--scrolly-progress, 0) * 0.55);
  }

  .hero-button {
    position: relative;
    z-index: 3;
    display: inline-flex;
    width: 290px;
    max-width: 100%;
    height: 64px;
    align-items: center;
    justify-content: center;
    gap: 14px;
    border-radius: 999px;
    color: #121212;
    background: #fff;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 1.2px;
  }

  .hero-button :global(svg) {
    flex: 0 0 auto;
  }

  .mountain {
    position: absolute;
    bottom: 0;
    left: 50%;
    width: 0;
    height: 0;
    border-right: 270px solid transparent;
    border-bottom: 320px solid #252729;
    border-left: 270px solid transparent;
    background: transparent;
    transform: translateX(-50%)
      translateY(calc(var(--scrolly-progress, 0) * -90px));
  }

  .scroll-cue {
    position: absolute;
    z-index: 4;
    right: 48px;
    bottom: 32px;
    display: grid;
    justify-items: center;
    gap: 10px;
    color: rgba(255, 255, 255, 0.9);
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 2px;
    writing-mode: vertical-rl;
    opacity: calc(1 - var(--scrolly-progress, 0) * 2.4);
  }

  .scroll-cue :global(svg) {
    animation: scroll-cue-bob 1.8s ease-in-out infinite;
  }

  @keyframes scroll-cue-bob {
    50% {
      transform: translateY(5px);
    }
  }

  .home-about {
    position: absolute;
    top: 813px;
    display: grid;
    width: 1440px;
    height: 369px;
    padding: 100px 104px 0;
    grid-template-columns: 430px 1fr;
    gap: 110px;
  }

  .about-heading h2 {
    margin: 20px 0 0;
    font-size: 44px;
    font-style: italic;
    font-weight: 700;
  }

  .about-copy {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    color: var(--ink-soft);
    font-size: 14px;
    letter-spacing: 0.5px;
    line-height: 23px;
  }

  .about-copy p {
    margin: 0;
  }

  .about-copy strong {
    color: var(--gold);
    font-size: 54px;
    font-style: italic;
    line-height: 0;
  }

  .home-toolbox {
    position: absolute;
    top: 1182px;
    width: 1440px;
    height: 1098px;
    padding-top: 105px;
    --full-bleed-background: #fdfcf9;
    background: #fdfcf9;
    text-align: center;
  }

  .home-toolbox h2,
  .home-healing h2 {
    margin: 20px 0 0;
    font-family: "Playfair Display", serif;
    font-size: 70px;
    font-style: italic;
    font-weight: 700;
    line-height: 1;
  }

  .activity-row {
    display: grid;
    margin: 80px 103px 0;
    grid-template-columns: repeat(3, 380px);
    gap: 40px;
    text-align: left;
  }

  .home-healing {
    position: absolute;
    top: 2280px;
    width: 1440px;
    height: 701px;
    padding-top: 85px;
    --full-bleed-background: var(--surface);
    background: var(--surface);
    text-align: center;
  }

  .healing-card {
    position: absolute;
    top: 270px;
    display: flex;
    width: 520px;
    align-items: center;
    gap: 35px;
    text-align: left;
  }

  .left-card {
    left: 180px;
  }

  .right-card {
    left: 760px;
  }

  .healing-card img {
    width: 210px;
    height: 210px;
    flex: 0 0 210px;
    border: 8px solid #fff;
    border-radius: 999px;
    object-fit: cover;
    box-shadow: 0 12px 24px rgba(18, 18, 18, 0.11);
  }

  .healing-card h3 {
    font-family: "Playfair Display", serif;
    font-size: 20px;
  }

  .healing-card p {
    color: #72716f;
    font-size: 12px;
    line-height: 20px;
  }

  .healing-card a {
    display: inline-block;
    margin-top: 15px;
    padding-bottom: 6px;
    border-bottom: 1px solid #c9c7c3;
    font-size: 9px;
    letter-spacing: 1.3px;
  }

  .home-corridor {
    position: absolute;
    top: 2981px;
    display: grid;
    width: 1440px;
    height: 725px;
    align-items: center;
    padding: 0 130px;
    grid-template-columns: 568px 1fr;
    gap: 85px;
  }

  .home-corridor img {
    width: 568px;
    height: 358px;
    border-radius: 20px;
    object-fit: cover;
    box-shadow: var(--shadow);
  }

  .home-corridor h2 {
    font-size: 32px;
    font-weight: 700;
    letter-spacing: 0.5px;
    line-height: 42px;
  }

  .home-corridor p {
    max-width: 545px;
    margin: 25px 0 32px;
    color: var(--ink-soft);
    line-height: 23px;
  }

  @media (max-width: 1439px) {
    .hero,
    .home-about,
    .home-toolbox,
    .home-healing,
    .home-corridor {
      position: relative;
      top: auto;
      width: 100%;
      height: auto;
    }

    .hero {
      min-height: clamp(540px, 80vw, 680px);
      padding: clamp(110px, 18vw, 150px) var(--page-gutter) 150px;
    }

    .hero .eyebrow {
      margin-top: 0;
    }

    .hero h1 {
      margin: 28px auto 32px;
      font-size: clamp(46px, 8vw, 72px);
      letter-spacing: -1.5px;
      line-height: 1.18;
      text-wrap: balance;
    }

    .hero h1 br {
      display: none;
    }

    .mountain {
      bottom: 0;
      left: 50%;
      width: 0;
      height: 0;
      border-right: clamp(150px, 22vw, 270px) solid transparent;
      border-bottom: clamp(180px, 26vw, 320px) solid #252729;
      border-left: clamp(150px, 22vw, 270px) solid transparent;
      transform: translateX(-50%)
        translateY(calc(var(--scrolly-progress, 0) * -90px));
    }

    .scroll-cue {
      right: var(--page-gutter);
      bottom: 28px;
    }

    .home-about {
      padding: var(--section-gap) var(--page-gutter);
      grid-template-columns: 1fr;
      gap: 42px;
    }

    .about-copy {
      grid-template-columns: 1fr;
      gap: clamp(18px, 3vw, 24px);
    }

    .home-toolbox,
    .home-healing {
      padding: var(--section-gap) var(--page-gutter);
    }

    .home-toolbox h2,
    .home-healing h2 {
      font-size: clamp(52px, 9vw, 70px);
    }

    .activity-row {
      width: 100%;
      margin: 64px 0 0;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 60px 28px;
    }

    .home-healing {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 56px 36px;
    }

    .home-healing > .eyebrow,
    .home-healing > h2 {
      grid-column: 1 / -1;
    }

    .healing-card,
    .left-card,
    .right-card {
      position: relative;
      top: auto;
      left: auto;
      width: auto;
      align-items: flex-start;
    }

    .healing-card img {
      width: clamp(150px, 18vw, 210px);
      height: clamp(150px, 18vw, 210px);
      flex-basis: clamp(150px, 18vw, 210px);
    }

    .home-corridor {
      padding: var(--section-gap) var(--page-gutter);
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      gap: clamp(42px, 7vw, 85px);
    }

    .home-corridor img {
      width: 100%;
      height: auto;
      aspect-ratio: 568 / 358;
    }
  }

  @media (max-width: 767px) {
    .scroll-cue {
      right: 20px;
      bottom: 18px;
      display: flex;
      align-items: center;
      gap: 8px;
      writing-mode: horizontal-tb;
    }

    .about-copy,
    .activity-row,
    .home-healing,
    .home-corridor {
      grid-template-columns: 1fr;
    }

    .healing-card {
      display: grid;
      justify-items: center;
      text-align: center;
    }

    .healing-card img {
      width: 190px;
      height: 190px;
      flex-basis: auto;
    }

    .home-corridor h2 br {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .scroll-cue :global(svg) {
      animation: none;
    }

    :global(.scrolly-enabled) [data-scrolly] {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>
