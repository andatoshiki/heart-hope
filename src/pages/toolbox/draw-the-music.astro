---
import ActivityActions from "../../components/react/ActivityActions";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { activities } from "../../data/content";
import movementDrama from "../../assets/images/movement-drama.png";
import musicSound from "../../assets/images/music-sound.png";
import emotionalColor from "../../assets/images/emotional-color.png";

const activity = activities[0];
---

<BaseLayout title="Draw the Music" height={2365}>
  <section class="detail-hero">
    <img src={musicSound.src} alt="A vinyl record and a single drawn line" />
    <a class="back" href="/toolbox" aria-label="Back to toolbox">←</a>
    <div class="detail-card shadow-panel">
      <p class="eyebrow">EXPLORE THE WORLD OF ART HEALING</p>
      <h1 class="serif">Music &amp; Sound</h1>
      <p class="activity-name">{activity.title}</p>
      <div class="materials">{activity.materials}</div>
      <ol>
        {activity.steps?.map((step) => <li>{step}</li>)}
      </ol>
      <div class="actions"><ActivityActions client:load /></div>
    </div>
  </section>
  <section class="related">
    <h2 class="serif">Related Works</h2>
    <div class="related-grid">
      <article>
        <img src={emotionalColor.src} alt="" />
        <h3 class="serif">Writing &amp; Poetry</h3>
      </article>
      <article>
        <img src={musicSound.src} alt="" />
        <h3 class="serif">Music &amp; Sound</h3>
      </article>
      <article>
        <img src={movementDrama.src} alt="" />
        <h3 class="serif">Movement &amp; Drama</h3>
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .detail-hero {
    position: absolute;
    top: 81px;
    width: 1440px;
    height: 1099px;
  }

  .detail-hero > img {
    width: 1440px;
    height: 550px;
    object-fit: cover;
    filter: grayscale(0.15) brightness(0.65);
  }

  .back {
    position: absolute;
    top: 32px;
    left: 32px;
    display: grid;
    width: 44px;
    height: 44px;
    place-items: center;
    border-radius: 50%;
    color: #fff;
    background: rgba(18, 18, 18, 0.7);
    font-size: 22px;
  }

  .detail-card {
    position: absolute;
    top: 406px;
    left: 296px;
    width: 832px;
    height: 693px;
    padding: 82px 88px 0;
    text-align: center;
  }

  .detail-card h1 {
    margin: 20px 0 23px;
    font-size: 58px;
    font-weight: 400;
    line-height: 80px;
  }

  .activity-name {
    margin: 0 0 34px;
    font-family: "Playfair Display", serif;
    font-size: 14px;
    font-weight: 700;
  }

  .materials {
    border-left: 4px solid var(--gold);
    padding-left: 30px;
    color: #72716f;
    font-size: 12px;
    letter-spacing: 0.5px;
    line-height: 20px;
    text-align: left;
  }

  ol {
    margin: 30px 0 0;
    padding-left: 18px;
    color: var(--ink-soft);
    font-size: 12px;
    letter-spacing: 0.5px;
    line-height: 23px;
    text-align: left;
  }

  .actions {
    position: absolute;
    bottom: 69px;
    left: 80px;
    width: 672px;
    padding-top: 48px;
    border-top: 1px solid #cfcece;
  }

  .related {
    position: absolute;
    top: 1304px;
    width: 1440px;
    text-align: center;
  }

  .related h2 {
    margin: 0;
    font-size: 32px;
    font-weight: 700;
  }

  .related-grid {
    display: grid;
    width: 832px;
    margin: 48px auto 0;
    grid-template-columns: repeat(3, 256px);
    gap: 32px;
    text-align: left;
  }

  .related img {
    width: 256px;
    height: 320px;
    border-radius: 20px;
    object-fit: cover;
  }

  .related h3 {
    font-size: 20px;
    font-weight: 700;
  }
</style>
